    "components": {
        "schemas": {
            "Category": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "name": {
                        "type": "string",
                        "maxLength": 100
                    },
                    "unit_type": {
                        "type": "string",
                        "maxLength": 20
                    }
                },
                "required": [
                    "id",
                    "name",
                    "unit_type"
                ]
            },
            "Customer": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "full_name": {
                        "type": "string",
                        "maxLength": 200
                    },
                    "phone": {
                        "type": "string",
                        "maxLength": 30
                    },
                    "default_address": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 500
                    }
                },
                "required": [
                    "full_name",
                    "id",
                    "phone"
                ]
            },
            "CustomerCreate": {
                "type": "object",
                "properties": {
                    "full_name": {
                        "type": "string",
                        "maxLength": 200
                    },
                    "phone": {
                        "type": "string",
                        "maxLength": 30
                    },
                    "default_address": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 500
                    },
                    "password": {
                        "type": "string",
                        "writeOnly": true
                    }
                },
                "required": [
                    "full_name",
                    "password",
                    "phone"
                ]
            },
            "CustomerUpdate": {
                "type": "object",
                "properties": {
                    "full_name": {
                        "type": "string",
                        "maxLength": 200
                    },
                    "phone": {
                        "type": "string",
                        "maxLength": 30
                    },
                    "default_address": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 500
                    },
                    "password": {
                        "type": "string",
                        "writeOnly": true
                    }
                }
            },
            "Order": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "customer_id": {
                        "type": "integer",
                        "nullable": true,
                        "readOnly": true
                    },
                    "customer_name": {
                        "type": "string",
                        "maxLength": 200
                    },
                    "customer_phone": {
                        "type": "string",
                        "maxLength": 30
                    },
                    "address": {
                        "type": "string",
                        "maxLength": 500
                    },
                    "status": {
                        "$ref": "#/components/schemas/OrderStatusEnum"
                    },
                    "total_price": {
                        "type": "integer",
                        "maximum": 9223372036854775807,
                        "minimum": -9223372036854775808,
                        "format": "int64"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "readOnly": true
                    },
                    "items": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/OrderItem"
                        },
                        "readOnly": true
                    }
                },
                "required": [
                    "address",
                    "created_at",
                    "customer_id",
                    "customer_name",
                    "customer_phone",
                    "id",
                    "items"
                ]
            },
            "OrderItem": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "product_id": {
                        "type": "integer",
                        "nullable": true,
                        "readOnly": true
                    },
                    "product_name": {
                        "type": "string",
                        "maxLength": 200
                    },
                    "unit_price": {
                        "type": "integer",
                        "maximum": 9223372036854775807,
                        "minimum": -9223372036854775808,
                        "format": "int64"
                    },
                    "quantity": {
                        "type": "integer",
                        "maximum": 9223372036854775807,
                        "minimum": -9223372036854775808,
                        "format": "int64"
                    },
                    "total_price": {
                        "type": "integer",
                        "maximum": 9223372036854775807,
                        "minimum": -9223372036854775808,
                        "format": "int64"
                    },
                    "image": {
                        "type": "string",
                        "readOnly": true
                    }
                },
                "required": [
                    "id",
                    "image",
                    "product_id",
                    "product_name",
                    "unit_price"
                ]
            },
            "OrderStatusEnum": {
                "enum": [
                    "new",
                    "confirmed",
                    "delivering",
                    "completed",
                    "canceled"
                ],
                "type": "string",
                "description": "* `new` - Yangi\n* `confirmed` - Tasdiqlangan\n* `delivering` - Yetkazilmoqda\n* `completed` - Yakunlangan\n* `canceled` - Bekor qilingan"
            },
            "PaginatedProductList": {
                "type": "object",
                "required": [
                    "count",
                    "results"
                ],
                "properties": {
                    "count": {
                        "type": "integer",
                        "example": 123
                    },
                    "next": {
                        "type": "string",
                        "nullable": true,
                        "format": "uri",
                        "example": "http://api.example.org/accounts/?offset=400&limit=100"
                    },
                    "previous": {
                        "type": "string",
                        "nullable": true,
                        "format": "uri",
                        "example": "http://api.example.org/accounts/?offset=200&limit=100"
                    },
                    "results": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Product"
                        }
                    }
                }
            },
            "PatchedCustomerUpdate": {
                "type": "object",
                "properties": {
                    "full_name": {
                        "type": "string",
                        "maxLength": 200
                    },
                    "phone": {
                        "type": "string",
                        "maxLength": 30
                    },
                    "default_address": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 500
                    },
                    "password": {
                        "type": "string",
                        "writeOnly": true
                    }
                }
            },
            "Product": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "name": {
                        "type": "string",
                        "maxLength": 200
                    },
                    "price": {
                        "type": "integer",
                        "maximum": 9223372036854775807,
                        "minimum": -9223372036854775808,
                        "format": "int64"
                    },
                    "description": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 500
                    },
                    "status": {
                        "$ref": "#/components/schemas/ProductStatusEnum"
                    },
                    "is_top": {
                        "type": "boolean"
                    },
                    "image": {
                        "type": "string",
                        "readOnly": true
                    },
                    "category": {
                        "allOf": [
                            {
                                "$ref": "#/components/schemas/Category"
                            }
                        ],
                        "readOnly": true
                    }
                },
                "required": [
                    "category",
                    "id",
                    "image",
                    "name",
                    "price"
                ]
            },
            "ProductStatusEnum": {
                "enum": [
                    "active",
                    "inactive"
                ],
                "type": "string",
                "description": "* `active` - Faol\n* `inactive` - Nofaol"
            }
        },
        "securitySchemes": {
            "basicAuth": {
                "type": "http",
                "scheme": "basic"
            },
            "cookieAuth": {
                "type": "apiKey",
                "in": "cookie",
                "name": "sessionid"
            }
        }
    }
}